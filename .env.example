# ── Discord Audio Bridge ─────────────────────
BOT_TOKEN=your-bot-token-here
VOICE_CHANNEL_ID=000000000000000000
AUDIO_DEVICE=CABLE Output (VB-Audio Virtual Cable)
FFMPEG_PATH=ffmpeg.exe
RECONNECT_DELAY=2

# ── Quality (only changes Opus bitrate, never touches FFmpeg) ──
# Presets: low (48kbps), balanced (128kbps), high (256kbps), ultra (384kbps)
AUDIO_QUALITY=balanced
BAD_INTERNET=false
ENABLE_CONSOLE=true
