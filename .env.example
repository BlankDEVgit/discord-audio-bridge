# ──────────────────────────────────────────────
#  Audio Retransmission Bot — Configuration
# ──────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  Lines starting with # are comments.
# ──────────────────────────────────────────────

# ── Required ─────────────────────────────────

# Your Discord bot token (from https://discord.com/developers/applications)
BOT_TOKEN=your-bot-token-here

# The voice channel ID to stream to (right-click channel → Copy Channel ID)
VOICE_CHANNEL_ID=000000000000000000

# ── Audio Device ─────────────────────────────

# Name of the virtual audio cable device (as shown in Windows Sound settings)
AUDIO_DEVICE=CABLE Output (VB-Audio Virtual Cable)

# Path to ffmpeg executable (default: ffmpeg.exe in project folder)
FFMPEG_PATH=ffmpeg.exe

# ── Latency Tuning ───────────────────────────
# These defaults are optimized for ultra-low latency.
# Only change them if you experience issues.

# DirectShow audio buffer in milliseconds (lower = less delay, more CPU)
AUDIO_BUFFER_SIZE=10

# FFmpeg probe size in bytes (lower = faster start)
PROBE_SIZE=32

# Read thread queue depth
THREAD_QUEUE_SIZE=32

# Real-time capture buffer size
RT_BUFFER_SIZE=64k

# ── Reconnection ─────────────────────────────

# Initial delay before reconnecting (seconds)
RECONNECT_DELAY=2

# Maximum reconnect delay cap (seconds)
MAX_RECONNECT_DELAY=30

# How often to check if the stream is still alive (seconds)
HEALTH_CHECK_INTERVAL=0.5

# ── Process Priority ─────────────────────────
# Options: "realtime", "high", "normal"
# Realtime gives lowest latency but requires admin privileges.
PROCESS_PRIORITY=high

# ── Bot Behavior ─────────────────────────────
# Deafen the bot in voice chat (recommended — prevents echo loops)
SELF_DEAF=true
